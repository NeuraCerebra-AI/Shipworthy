{
  "$defs": {
    "Action": {
      "enum": [
        "Fix",
        "Prove",
        "Decide",
        "Skip",
        "Keep"
      ],
      "title": "Action",
      "type": "string"
    },
    "Artifact": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "availability": {
                "const": "available"
              }
            },
            "required": [
              "availability"
            ]
          },
          "then": {
            "properties": {
              "descriptor": {
                "properties": {
                  "byte_size": {
                    "type": "integer"
                  },
                  "digest": {
                    "type": "string"
                  }
                },
                "required": [
                  "byte_size",
                  "digest"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "availability": {
                "const": "missing"
              }
            },
            "required": [
              "availability"
            ]
          },
          "then": {
            "properties": {
              "descriptor": {
                "properties": {
                  "byte_size": {
                    "type": "null"
                  },
                  "digest": {
                    "type": "null"
                  }
                },
                "required": [
                  "byte_size",
                  "digest"
                ]
              }
            }
          }
        }
      ],
      "properties": {
        "artifact_id": {
          "maxLength": 67,
          "minLength": 5,
          "pattern": "^ART-[A-Z0-9][A-Z0-9._-]{0,62}$",
          "title": "Artifact Id",
          "type": "string"
        },
        "availability": {
          "$ref": "#/$defs/ArtifactAvailability"
        },
        "custody_state": {
          "$ref": "#/$defs/CustodyState"
        },
        "descriptor": {
          "$ref": "#/$defs/ArtifactDescriptor"
        },
        "lineage": {
          "$ref": "#/$defs/ArtifactLineage"
        }
      },
      "required": [
        "artifact_id",
        "availability",
        "descriptor",
        "lineage",
        "custody_state"
      ],
      "title": "Artifact",
      "type": "object"
    },
    "ArtifactAvailability": {
      "enum": [
        "available",
        "missing",
        "corrupt",
        "externally_linked"
      ],
      "title": "ArtifactAvailability",
      "type": "string"
    },
    "ArtifactDescriptor": {
      "additionalProperties": false,
      "properties": {
        "byte_size": {
          "anyOf": [
            {
              "maximum": 1073741824,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "title": "Byte Size"
        },
        "declared_media_type": {
          "maxLength": 255,
          "minLength": 3,
          "pattern": "^[a-z0-9][a-z0-9!#$&^_.+-]{0,126}/[a-z0-9][a-z0-9!#$&^_.+-]{0,126}$",
          "title": "Declared Media Type",
          "type": "string"
        },
        "digest": {
          "anyOf": [
            {
              "maxLength": 64,
              "minLength": 64,
              "pattern": "^[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Digest"
        },
        "digest_algorithm": {
          "pattern": "^sha256$",
          "title": "Digest Algorithm",
          "type": "string"
        },
        "relative_path": {
          "maxLength": 512,
          "minLength": 1,
          "pattern": "^(?:[A-Za-z0-9_-][A-Za-z0-9._-]*/)*[A-Za-z0-9_-][A-Za-z0-9._-]*$",
          "title": "Relative Path",
          "type": "string"
        }
      },
      "required": [
        "relative_path",
        "declared_media_type",
        "digest_algorithm",
        "digest",
        "byte_size"
      ],
      "title": "ArtifactDescriptor",
      "type": "object"
    },
    "ArtifactLineage": {
      "additionalProperties": false,
      "properties": {
        "operation": {
          "maxLength": 200,
          "minLength": 1,
          "title": "Operation",
          "type": "string"
        },
        "producer": {
          "maxLength": 64,
          "minLength": 1,
          "title": "Producer",
          "type": "string"
        },
        "source_ids": {
          "items": {
            "maxLength": 71,
            "minLength": 4,
            "pattern": "^[A-Z][A-Z0-9]{1,7}-[A-Z0-9][A-Z0-9._-]{0,62}$",
            "type": "string"
          },
          "maxItems": 128,
          "title": "Source Ids",
          "type": "array",
          "uniqueItems": true
        }
      },
      "required": [
        "producer",
        "operation",
        "source_ids"
      ],
      "title": "ArtifactLineage",
      "type": "object"
    },
    "CompletionStatus": {
      "enum": [
        "complete",
        "incomplete"
      ],
      "title": "CompletionStatus",
      "type": "string"
    },
    "Confidence": {
      "enum": [
        "Confirmed",
        "Strong",
        "Provisional",
        "Hypothesis"
      ],
      "title": "Confidence",
      "type": "string"
    },
    "ConfirmedOnlyGateContract": {
      "additionalProperties": false,
      "properties": {
        "policy": {
          "$ref": "#/$defs/GatePolicy"
        }
      },
      "required": [
        "policy"
      ],
      "title": "ConfirmedOnlyGateContract",
      "type": "object"
    },
    "CustodyState": {
      "enum": [
        "LOCAL_CONTENT_INTEGRITY"
      ],
      "title": "CustodyState",
      "type": "string"
    },
    "DebtStatus": {
      "enum": [
        "needs-proof",
        "blocked",
        "scoped-out"
      ],
      "title": "DebtStatus",
      "type": "string"
    },
    "EvidenceDebt": {
      "additionalProperties": false,
      "properties": {
        "artifact_ids": {
          "items": {
            "maxLength": 67,
            "minLength": 5,
            "pattern": "^ART-[A-Z0-9][A-Z0-9._-]{0,62}$",
            "type": "string"
          },
          "maxItems": 128,
          "title": "Artifact Ids",
          "type": "array",
          "uniqueItems": true
        },
        "debt_id": {
          "maxLength": 66,
          "minLength": 4,
          "pattern": "^ED-[A-Z0-9][A-Z0-9._-]{0,62}$",
          "title": "Debt Id",
          "type": "string"
        },
        "proof_needed": {
          "maxLength": 1000,
          "minLength": 1,
          "title": "Proof Needed",
          "type": "string"
        },
        "reason": {
          "maxLength": 1000,
          "minLength": 1,
          "title": "Reason",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/DebtStatus"
        },
        "subject": {
          "maxLength": 200,
          "minLength": 1,
          "title": "Subject",
          "type": "string"
        }
      },
      "required": [
        "debt_id",
        "subject",
        "proof_needed",
        "reason",
        "status",
        "artifact_ids"
      ],
      "title": "EvidenceDebt",
      "type": "object"
    },
    "Finding": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "proof": {
                "const": "Confirmed"
              }
            },
            "required": [
              "proof"
            ]
          },
          "then": {
            "properties": {
              "artifact_ids": {
                "minItems": 1
              },
              "confidence": {
                "const": "Confirmed"
              },
              "verifier_status": {
                "const": "approved"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "proof": {
                "const": "Confirmed"
              },
              "severity": {
                "const": "P0 Blocker"
              }
            },
            "required": [
              "proof",
              "severity"
            ]
          },
          "then": {
            "properties": {
              "action": {
                "const": "Fix"
              },
              "section": {
                "const": "clear_before_ship"
              }
            }
          }
        }
      ],
      "properties": {
        "action": {
          "$ref": "#/$defs/Action"
        },
        "affected_semantic_keys": {
          "items": {
            "maxLength": 512,
            "minLength": 3,
            "type": "string"
          },
          "maxItems": 128,
          "type": "array",
          "uniqueItems": true
        },
        "artifact_ids": {
          "items": {
            "maxLength": 67,
            "minLength": 5,
            "pattern": "^ART-[A-Z0-9][A-Z0-9._-]{0,62}$",
            "type": "string"
          },
          "maxItems": 128,
          "title": "Artifact Ids",
          "type": "array",
          "uniqueItems": true
        },
        "confidence": {
          "$ref": "#/$defs/Confidence"
        },
        "finding_id": {
          "maxLength": 67,
          "minLength": 5,
          "pattern": "^FND-[A-Z0-9][A-Z0-9._-]{0,62}$",
          "title": "Finding Id",
          "type": "string"
        },
        "evidence_refs": {
          "items": {
            "maxLength": 512,
            "minLength": 1,
            "type": "string"
          },
          "maxItems": 128,
          "type": "array",
          "uniqueItems": true
        },
        "observed_effect_code": {
          "maxLength": 128,
          "minLength": 1,
          "type": "string"
        },
        "proof": {
          "$ref": "#/$defs/Proof"
        },
        "revision": {
          "maximum": 2147483647,
          "minimum": 1,
          "title": "Revision",
          "type": "integer"
        },
        "section": {
          "$ref": "#/$defs/FindingSection"
        },
        "severity": {
          "$ref": "#/$defs/Severity"
        },
        "subject": {
          "$ref": "#/$defs/FindingSubject"
        },
        "summary": {
          "maxLength": 1000,
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        },
        "verifier_status": {
          "$ref": "#/$defs/VerifierStatus"
        }
      },
      "required": [
        "finding_id",
        "revision",
        "subject",
        "action",
        "proof",
        "section",
        "severity",
        "confidence",
        "verifier_status",
        "summary",
        "artifact_ids"
      ],
      "title": "Finding",
      "type": "object"
    },
    "FindingSection": {
      "enum": [
        "clear_before_ship",
        "fix_next",
        "not_proven_not_tested",
        "passed_keep"
      ],
      "title": "FindingSection",
      "type": "string"
    },
    "FindingSubject": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "$ref": "#/$defs/SubjectKind"
        },
        "location": {
          "anyOf": [
            {
              "maxLength": 512,
              "minLength": 1,
              "pattern": "^(?:[A-Za-z0-9_-][A-Za-z0-9._-]*/)*[A-Za-z0-9_-][A-Za-z0-9._-]*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Location"
        },
        "ref": {
          "maxLength": 200,
          "minLength": 1,
          "title": "Ref",
          "type": "string"
        },
        "title": {
          "maxLength": 200,
          "minLength": 1,
          "title": "Title",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "ref",
        "title",
        "location"
      ],
      "title": "FindingSubject",
      "type": "object"
    },
    "GatePolicy": {
      "enum": [
        "confirmed_only"
      ],
      "title": "GatePolicy",
      "type": "string"
    },
    "Producer": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "maxLength": 64,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "version": {
          "maxLength": 32,
          "minLength": 1,
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "name",
        "version"
      ],
      "title": "Producer",
      "type": "object"
    },
    "Proof": {
      "enum": [
        "Confirmed",
        "Partial",
        "Inferred",
        "Not tested"
      ],
      "title": "Proof",
      "type": "string"
    },
    "ReadinessDisposition": {
      "enum": [
        "ready",
        "conditionally_ready",
        "not_ready",
        "cannot_determine"
      ],
      "title": "ReadinessDisposition",
      "type": "string"
    },
    "Severity": {
      "enum": [
        "P0 Blocker",
        "P1 Major",
        "P2 Moderate",
        "P3 Minor",
        "Unscored"
      ],
      "title": "Severity",
      "type": "string"
    },
    "SubjectKind": {
      "enum": [
        "workflow",
        "path",
        "artifact",
        "release_gate",
        "evidence_gap"
      ],
      "title": "SubjectKind",
      "type": "string"
    },
    "FrontierObservation": {
      "additionalProperties": false,
      "properties": {
        "method_taxonomy_version": {"const": "shipworthy-methods-v1"},
        "method_family": {"enum": ["runtime_human_interaction", "runtime_structural_inventory", "static_implementation_inventory", "declared_behavior_inventory"]},
        "method_detail": {"minLength": 1, "maxLength": 200, "type": "string"},
        "provenance": {"minLength": 1, "maxLength": 200, "type": "string"},
        "role": {"minLength": 1, "maxLength": 100, "type": "string"},
        "state": {"minLength": 1, "maxLength": 100, "type": "string"},
        "viewport": {"minLength": 1, "maxLength": 100, "type": "string"},
        "discovery_pass_id": {"minLength": 1, "maxLength": 100, "type": "string"},
        "evidence_refs": {"type": "array", "minItems": 1, "maxItems": 128, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 512}}
      },
      "required": ["method_taxonomy_version", "method_family", "method_detail", "provenance", "role", "state", "viewport", "discovery_pass_id", "evidence_refs"],
      "type": "object"
    },
    "FrontierRow": {
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "pattern": "^PF-[A-Z0-9][A-Z0-9._-]{0,62}$"},
        "kind": {"enum": ["intent", "feature", "surface", "control", "transition"]},
        "parent_id": {"anyOf": [{"type": "string", "pattern": "^PF-[A-Z0-9][A-Z0-9._-]{0,62}$"}, {"type": "null"}]},
        "semantic_key": {"type": "string", "minLength": 3, "maxLength": 512, "pattern": "^(intent|feature|surface|control|transition):[a-z0-9/_:-]+$"},
        "normalization_version": {"const": "shipworthy-semantic-v1"},
        "method_taxonomy_version": {"const": "shipworthy-methods-v1"},
        "status": {"enum": ["covered", "sampled_with_justification", "blocked", "avoided", "missing", "out_of_scope", "evidence_debt", "unattempted", "unknown", "maybe"]},
        "material": {"type": "boolean"},
        "attempt_count": {"type": "integer", "minimum": 0},
        "evidence_refs": {"type": "array", "maxItems": 128, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 512}},
        "observations": {"type": "array", "maxItems": 128, "items": {"$ref": "#/$defs/FrontierObservation"}},
        "control_identity": {
          "additionalProperties": false,
          "properties": {
            "name": {"type": "string", "minLength": 1, "maxLength": 200},
            "control_type": {"type": "string", "minLength": 1, "maxLength": 100},
            "disambiguator": {"type": "string", "minLength": 1, "maxLength": 200}
          },
          "required": ["name", "control_type", "disambiguator"],
          "type": "object"
        },
        "before_state": {"type": "string", "minLength": 1, "maxLength": 200},
        "after_state": {"type": "string", "minLength": 1, "maxLength": 200},
        "terminal_reason": {"type": "string", "minLength": 1, "maxLength": 1000},
        "sample_justification": {"type": "string", "minLength": 1, "maxLength": 1000}
      },
      "required": ["id", "kind", "semantic_key", "normalization_version", "method_taxonomy_version", "status", "material", "attempt_count", "evidence_refs", "observations"],
      "type": "object"
    },
    "FrontierDiscoveryPass": {
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "minLength": 1, "maxLength": 100},
        "method_taxonomy_version": {"const": "shipworthy-methods-v1"},
        "method_family": {"enum": ["runtime_human_interaction", "runtime_structural_inventory", "static_implementation_inventory", "declared_behavior_inventory"]},
        "role": {"type": "string", "minLength": 1, "maxLength": 100},
        "fixture": {"type": "string", "minLength": 1, "maxLength": 200},
        "viewport": {"type": "string", "minLength": 1, "maxLength": 100},
        "starting_frontier_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "ending_frontier_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "new_semantic_keys": {"type": "array", "maxItems": 1024, "uniqueItems": true, "items": {"type": "string", "minLength": 3, "maxLength": 512}}
      },
      "required": ["id", "method_taxonomy_version", "method_family", "role", "fixture", "viewport", "starting_frontier_digest", "ending_frontier_digest", "new_semantic_keys"],
      "type": "object"
    },
    "path_frontier": {
      "additionalProperties": false,
      "properties": {
        "normalization_version": {"const": "shipworthy-semantic-v1"},
        "method_taxonomy_version": {"const": "shipworthy-methods-v1"},
        "closure_state": {"enum": ["closed_multi_source", "incomplete", "single_source", "blocked", "static_only"]},
        "closure_reason": {"type": "string", "minLength": 1, "maxLength": 1000},
        "summary": {
          "additionalProperties": false,
          "properties": {
            "intent": {"type": "integer", "minimum": 0},
            "feature": {"type": "integer", "minimum": 0},
            "surface": {"type": "integer", "minimum": 0},
            "control": {"type": "integer", "minimum": 0},
            "transition": {"type": "integer", "minimum": 0}
          },
          "required": ["intent", "feature", "surface", "control", "transition"],
          "type": "object"
        },
        "rows": {"type": "array", "maxItems": 10000, "items": {"$ref": "#/$defs/FrontierRow"}},
        "discovery_passes": {"type": "array", "maxItems": 256, "items": {"$ref": "#/$defs/FrontierDiscoveryPass"}},
        "reconciliation_differences": {
          "type": "array",
          "maxItems": 1024,
          "items": {
            "additionalProperties": false,
            "properties": {
              "semantic_key": {"type": "string", "minLength": 3, "maxLength": 512},
              "reason": {"type": "string", "minLength": 1, "maxLength": 1000}
            },
            "required": ["semantic_key", "reason"],
            "type": "object"
          }
        },
        "manifest_artifact": {"type": "string", "minLength": 1, "maxLength": 512}
      },
      "required": ["normalization_version", "method_taxonomy_version", "closure_state", "summary", "rows", "discovery_passes", "reconciliation_differences"],
      "type": "object"
    },
    "VerifierStatus": {
      "enum": [
        "approved",
        "downgraded",
        "rejected",
        "needs-proof",
        "blocked"
      ],
      "title": "VerifierStatus",
      "type": "string"
    }
  },
  "$id": "https://shipworthy.local/schemas/v1/readiness-ledger.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "findings": {
            "contains": {
              "anyOf": [
                {
                  "properties": {
                    "proof": {
                      "const": "Not tested"
                    }
                  },
                  "required": [
                    "proof"
                  ]
                },
                {
                  "properties": {
                    "verifier_status": {
                      "enum": [
                        "needs-proof",
                        "blocked"
                      ]
                    }
                  },
                  "required": [
                    "verifier_status"
                  ]
                }
              ]
            }
          }
        },
        "required": [
          "findings"
        ]
      },
      "then": {
        "properties": {
          "completion_status": {
            "const": "incomplete"
          },
          "evidence_debt": {
            "contains": {
              "properties": {
                "status": {
                  "enum": [
                    "needs-proof",
                    "blocked"
                  ]
                }
              },
              "required": [
                "status"
              ]
            },
            "minItems": 1
          },
          "readiness_disposition": {
            "const": "cannot_determine"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "completion_status": {
            "const": "incomplete"
          }
        },
        "required": [
          "completion_status"
        ]
      },
      "then": {
        "anyOf": [
          {
            "properties": {
              "evidence_debt": {
                "contains": {
                  "properties": {
                    "status": {
                      "enum": [
                        "needs-proof",
                        "blocked"
                      ]
                    }
                  },
                  "required": [
                    "status"
                  ]
                }
              }
            }
          },
          {
            "properties": {
              "artifacts": {
                "contains": {
                  "properties": {
                    "availability": {
                      "enum": [
                        "missing",
                        "corrupt",
                        "externally_linked"
                      ]
                    }
                  },
                  "required": [
                    "availability"
                  ]
                }
              }
            }
          }
        ]
      }
    },
    {
      "if": {
        "properties": {
          "completion_status": {
            "const": "complete"
          }
        },
        "required": [
          "completion_status"
        ]
      },
      "then": {
        "properties": {
          "artifacts": {
            "not": {
              "contains": {
                "properties": {
                  "availability": {
                    "enum": [
                      "missing",
                      "corrupt",
                      "externally_linked"
                    ]
                  }
                },
                "required": [
                  "availability"
                ]
              }
            }
          },
          "evidence_debt": {
            "not": {
              "contains": {
                "properties": {
                  "status": {
                    "enum": [
                      "needs-proof",
                      "blocked"
                    ]
                  }
                },
                "required": [
                  "status"
                ]
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "allOf": [
          {
            "properties": {
              "findings": {
                "not": {
                  "contains": {
                    "anyOf": [
                      {
                        "properties": {
                          "proof": {
                            "const": "Not tested"
                          }
                        },
                        "required": [
                          "proof"
                        ]
                      },
                      {
                        "properties": {
                          "verifier_status": {
                            "enum": [
                              "needs-proof",
                              "blocked"
                            ]
                          }
                        },
                        "required": [
                          "verifier_status"
                        ]
                      }
                    ]
                  }
                }
              }
            },
            "required": [
              "findings"
            ]
          },
          {
            "properties": {
              "findings": {
                "contains": {
                  "properties": {
                    "action": {
                      "const": "Fix"
                    },
                    "confidence": {
                      "const": "Confirmed"
                    },
                    "proof": {
                      "const": "Confirmed"
