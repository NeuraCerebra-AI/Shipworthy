{
  "$defs": {
    "Producer": {
      "$ref": "readiness-ledger.schema.json#/$defs/Producer"
    },
    "ReadinessLedger": {
      "$ref": "readiness-ledger.schema.json"
    },
    "path_frontier": {
      "$ref": "readiness-ledger.schema.json#/$defs/path_frontier"
    }
  },
  "$id": "https://shipworthy.local/schemas/v1/report-input.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "generated_at": {
      "format": "date-time",
      "maxLength": 20,
      "minLength": 20,
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$",
      "title": "Generated At",
      "type": "string"
    },
    "producer": {
      "$ref": "#/$defs/Producer"
    },
    "report_input_id": {
      "maxLength": 67,
      "minLength": 5,
      "pattern": "^RPT-[A-Z0-9][A-Z0-9._-]{0,62}$",
      "title": "Report Input Id",
      "type": "string"
    },
    "schema_name": {
      "pattern": "^shipworthy/readiness-report-input$",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "pattern": "^1\\.0$",
      "title": "Schema Version",
      "type": "string"
    },
    "source_ledger": {
      "$ref": "#/$defs/ReadinessLedger"
    }
  },
  "required": [
    "schema_name",
    "schema_version",
    "generated_at",
    "producer",
    "report_input_id",
    "source_ledger"
  ],
  "title": "ReportInput",
  "type": "object"
}
